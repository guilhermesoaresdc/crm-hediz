# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta (Marketing + Lead Ads + CAPI)
# App ID precisa ser public para o OAuth redirect funcionar no browser
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=change-me

# Embedded Signup com Coexistence (CoEx) — opcional
# Crie no painel Meta: Embedded Signup > New Configuration > tipo Coexistence
NEXT_PUBLIC_META_EMBEDDED_CONFIG_ID=

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=change-me

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis (locks/rate limit)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email
RESEND_API_KEY=

# Monitoring
SENTRY_DSN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
